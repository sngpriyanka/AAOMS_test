# ==================== BOMBAY TROOPER - PROJECT SETUP ====================
# This is a sample environment configuration file.
# Copy this file and rename it to .env in both frontend/ and backend/ directories
# Then update the values according to your setup

# ==================== BACKEND SETUP ====================
# Create backend/.env with the following:

# Server Configuration
# PORT=5000
# NODE_ENV=development

# JWT Secret (CHANGE THIS IN PRODUCTION)
# JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# CORS Configuration
# FRONTEND_URL=https://aaoms-test.onrender.com

# Database
# DATABASE_TYPE=json
# DATABASE_PATH=./data

# eSewa Payment Gateway (Testing)
# ESEWA_MERCHANT_ID=EPAYTEST
# ESEWA_PAYMENT_URL=https://uat.esewa.com.np/epay/main

# Khalti Payment Gateway (Testing)
# KHALTI_PUBLIC_KEY=test_public_key_xxxxxxxxxxxxxxx
# KHALTI_SECRET_KEY=test_secret_key_xxxxxxxxxxxxxxx

# ==================== FRONTEND SETUP ====================
# Create frontend/.env with the following:

# API Configuration
# REACT_APP_API_URL=http://localhost:5000/api

# eSewa Configuration (Testing)
# REACT_APP_ESEWA_MERCHANT_ID=EPAYTEST
# REACT_APP_ESEWA_PAYMENT_URL=https://uat.esewa.com.np/epay/main

# Khalti Configuration (Testing)
# REACT_APP_KHALTI_PUBLIC_KEY=test_public_key_xxxxxxxxxxxxxxx

# ==================== QUICK START ====================
# 1. Copy backend/.env.sample to backend/.env
# 2. Copy frontend/.env.sample to frontend/.env
# 3. Update values as needed for your setup
# 4. Never commit .env files to version control
# 5. Always commit .env.sample with placeholder values

# ==================== IMPORTANT ====================
# Never commit .env files to Git!
# Always use .env.sample as template for new developers
# Change JWT_SECRET in production
# Use real payment gateway credentials in production
# See .env.sample files in frontend/ and backend/ for detailed configuration
