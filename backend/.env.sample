# ==================== SERVER CONFIGURATION ====================
PORT=5000
NODE_ENV=development

# ==================== JWT AUTHENTICATION ====================
# Generate a strong secret key for production!
JWT_SECRET=your_jwt_secret_key_change_in_production_12345

# ==================== CORS CONFIGURATION ====================
FRONTEND_URL=https://reliable-chimera-549542.netlify.app/

# ==================== DATABASE CONFIGURATION ====================
# Choose between JSON (development) or MongoDB (production)
# DATABASE_TYPE=json     # File-based (quick setup, not suitable for production)
# DATABASE_TYPE=mongodb  # Cloud database (recommended - MongoDB Atlas)

DATABASE_TYPE=mongodb
DATABASE_PATH=./data

# MongoDB Atlas Setup (Takes 5 minutes):
# 1. Go to https://www.mongodb.com/cloud/atlas
# 2. Sign up (free tier available)
# 3. Create a cluster
# 4. Create a database user (username: bombay_trooper)
# 5. Get connection string from Atlas dashboard
# 6. Replace MONGODB_URI below with your connection string
# 7. Install mongoose: npm install mongoose

# Connection string format:
# mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority

MONGODB_URI=mongodb+srv://bombay_trooper:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/bombay_trooper?retryWrites=true&w=majority

# ==================== ESEWA PAYMENT GATEWAY ====================
# For Testing: Use EPAYTEST merchant ID
# Get your credentials from: https://esewa.com.np/
ESEWA_MERCHANT_ID=EPAYTEST
ESEWA_SUCCESS_URL=https://reliable-chimera-549542.netlify.app/payment/success
ESEWA_FAILURE_URL=https://reliable-chimera-549542.netlify.app/payment/failure
ESEWA_PAYMENT_URL=https://uat.esewa.com.np/epay/main

# For Production (update when deploying):
# ESEWA_MERCHANT_ID=your_production_merchant_id
# ESEWA_PAYMENT_URL=https://esewa.com.np/epay/main

# ==================== KHALTI PAYMENT GATEWAY ====================
# Get your credentials from: https://khalti.com/developers/dashboard/
KHALTI_PUBLIC_KEY=test_public_key_xxxxxxxxxxxxxxx
KHALTI_SECRET_KEY=test_secret_key_xxxxxxxxxxxxxxx
KHALTI_PAYMENT_URL=https://khalti.com/api/payment/

# ==================== EMAIL SERVICE (Optional) ====================
# Currently optional. Uncomment and configure when ready to send emails
# EMAIL_SERVICE=gmail
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password
# EMAIL_FROM=noreply@bombaytroooper.com

# ==================== API RATE LIMITING ====================
# Limit requests to prevent abuse
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# ==================== LOGGING ====================
# LOG_LEVEL=info
# LOG_FILE=./logs/app.log
