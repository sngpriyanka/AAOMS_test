# ==================== API CONFIGURATION ====================
# Backend API URL - Change to production URL when deploying
REACT_APP_API_URL=https://aaoms-test.onrender.com/api

# ==================== GOOGLE OAUTH ====================
# Get your Client ID from: https://console.cloud.google.com/
# Steps: APIs & Services > Credentials > Create OAuth 2.0 Client ID
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# ==================== ESEWA PAYMENT GATEWAY ====================
# Get your credentials from: https://esewa.com.np/
# For Testing: Use EPAYTEST merchant ID
REACT_APP_ESEWA_MERCHANT_ID=EPAYTEST
REACT_APP_ESEWA_SUCCESS_URL=https://reliable-chimera-549542.netlify.app/payment/success
REACT_APP_ESEWA_FAILURE_URL=https://reliable-chimera-549542.netlify.app/payment/failure
REACT_APP_ESEWA_PAYMENT_URL=https://uat.esewa.com.np/epay/main

# For Production (update when deploying):
# REACT_APP_ESEWA_MERCHANT_ID=your_production_merchant_id
# REACT_APP_ESEWA_PAYMENT_URL=https://esewa.com.np/epay/main

# ==================== KHALTI PAYMENT GATEWAY ====================
# Get your credentials from: https://khalti.com/developers/dashboard/
REACT_APP_KHALTI_PUBLIC_KEY=test_public_key_xxxxxxxxxxxxxxx
REACT_APP_KHALTI_PAYMENT_URL=https://khalti.com/api/payment/

# ==================== APPLICATION SETTINGS ====================
# Valid values: development, staging, production
REACT_APP_ENV=development
